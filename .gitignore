# === OS junk ===
Thumbs.db
.DS_Store
desktop.ini

# === IDE / editor ===
.idea/
.vscode/
*.iml
*.swp

# === Java / Maven / Gradle ===
target/
build/
.gradle/
*.class
*.jar
*.war
!gradle/wrapper/gradle-wrapper.jar
!.mvn/wrapper/maven-wrapper.jar

# === Node / Angular ===
node_modules/
dist/
.angular/
npm-debug.log*
yarn-error.log

# === Python ===
__pycache__/
*.py[cod]
.venv/
.uv-cache/

# === Terraform ===
.terraform/
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example

# === Secrets / env ===
.env
.env.*
!.env.example
*.pem
*.key

# === Logs / temp ===
*.log
tmp/

# === Audit sink (local dev JSONL appender) ===
var/audit/

# === Spec Kit / Claude Code local state ===
# Ignore Claude Code's auth, cache, and per-user settings.
# Keep the skills/ folder because it's part of the project's workflow definition.
.claude/settings.local.json
.claude/.credentials*
.claude/auth*
.claude/cache/
.claude/logs/
.claude/state/
.claude/*.local.*

# Spec Kit local runtime state (logs, tmp), but keep templates/workflows/scripts.
.specify/.cache/
.specify/logs/
.specify/tmp/

# === Claude Code worktrees (managed by Claude Code, not part of repo) ===
.claude/worktrees/
