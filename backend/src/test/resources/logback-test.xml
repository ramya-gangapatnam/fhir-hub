<?xml version="1.0" encoding="UTF-8"?>
<!--
  Test-scope Logback configuration. Picked up by Spring Boot's LogbackLoggingSystem
  (which searches for logback-test.xml before logback-spring.xml), so @SpringBootTest
  contexts boot cleanly even while the production logback-spring.xml is being
  iterated on.

  Keeps the MaskingConverter wired so PhiRedactionIntegrationTest (T025) can still
  assert SC-005 against the same redaction surface used in production.
-->
<configuration scan="false">

  <conversionRule conversionWord="msg"
      converterClass="io.github.ramyagangapatnam.fhirhub.observability.MaskingConverter"/>
  <conversionRule conversionWord="m"
      converterClass="io.github.ramyagangapatnam.fhirhub.observability.MaskingConverter"/>

  <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{40} cid=%X{correlation_id:-} - %msg%n</pattern>
    </encoder>
  </appender>

  <root level="INFO">
    <appender-ref ref="STDOUT"/>
  </root>

  <logger name="io.github.ramyagangapatnam.fhirhub" level="DEBUG"/>
  <logger name="org.springframework" level="WARN"/>
  <logger name="org.hibernate" level="WARN"/>
  <logger name="org.testcontainers" level="INFO"/>
</configuration>
